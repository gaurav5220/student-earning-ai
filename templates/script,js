/**
 * Escapes HTML special characters
 * @param {string} text - The text to escape
 * @returns {string} - The escaped text
 */
function escapeHtml(text) {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
}

/**
 * Formats a timestamp as relative time
 * @param {string} timestamp - ISO timestamp
 * @returns {string} - Formatted relative time
 */
function formatRelativeTime(timestamp) {
    const date = new Date(timestamp);
    const now = new Date();
    const diffMs = now - date;
    const diffSecs = Math.floor(diffMs / 1000);
    const diffMins = Math.floor(diffSecs / 60);
    const diffHours = Math.floor(diffMins / 60);
    const diffDays = Math.floor(diffHours / 24);
    
    if (diffSecs < 60) return 'Just now';
    if (diffMins < 60) return `${diffMins} min${diffMins > 1 ? 's' : ''} ago`;
    if (diffHours < 24) return `${diffHours} hour${diffHours > 1 ? 's' : ''} ago`;
    if (diffDays < 7) return `${diffDays} day${diffDays > 1 ? 's' : ''} ago`;
    
    return date.toLocaleDateString('en-US', { 
        month: 'short', 
        day: 'numeric',
        year: date.getFullYear() !== now.getFullYear() ? 'numeric' : undefined
    });
}

/**
 * Counts words in a text
 * @param {string} text - The text to count
 * @returns {number} - Word count
 */
function countWords(text) {
    return text.trim().split(/\s+/).filter(word => word.length > 0).length;
}

/**
 * Updates the character count display
 */
function updateCharCount() {
    const count = elements.promptInput.value.length;
    elements.charCount.textContent = count;
    
    if (count > 2000) {
        elements.charCount.style.color = 'var(--danger)';
    } else if (count > 1800) {
        elements.charCount.style.color = 'var(--warning)';
    } else {
        elements.charCount.style.color = '';
    }
}

// ============================================
// EVENT LISTENERS
// ============================================

function initializeEventListeners() {
    // Sidebar controls
    elements.openSidebarBtn.addEventListener('click', openSidebar);
    elements.closeSidebarBtn.addEventListener('click', closeSidebar);
    elements.sidebarOverlay.addEventListener('click', closeSidebar);
    
    // History
    elements.clearHistoryBtn.addEventListener('click', clearHistory);
    
    // Input
    elements.promptInput.addEventListener('input', updateCharCount);
    elements.promptInput.addEventListener('keydown', (e) => {
        // Ctrl/Cmd + Enter to generate
        if ((e.ctrlKey || e.metaKey) && e.key === 'Enter') {
            e.preventDefault();
            handleGenerate();
        }
    });
    
    // Quick prompts
    document.querySelectorAll('.chip[data-prompt]').forEach(chip => {
        chip.addEventListener('click', () => {
            const promptText = chip.dataset.prompt;
            elements.promptInput.value = promptText;
            updateCharCount();
            elements.promptInput.focus();
        });
    });
    
    // Generate
    elements.generateBtn.addEventListener('click', handleGenerate);
    
    // Output actions
    elements.regenerateBtn.addEventListener('click', handleRegenerate);
    elements.copyBtn.addEventListener('click', copyToClipboard);
    elements.downloadBtn.addEventListener('click', downloadResult);
    elements.retryBtn.addEventListener('click', handleGenerate);
    
    // Handle escape key to close sidebar
    document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') {
            closeSidebar();
        }
    });
    
    // Handle window resize
    window.addEventListener('resize', () => {
        if (window.innerWidth > 1024) {
            closeSidebar();
        }
    });
}

// ============================================
// INITIALIZATION
// ============================================

function initialize() {
    // Initialize Lucide icons
    lucide.createIcons();
    
    // Load history from localStorage
    loadHistory();
    
    // Initialize event listeners
    initializeEventListeners();
    
    // Update character count
    updateCharCount();
    
    // Focus input on desktop
    if (window.innerWidth > 768) {
        elements.promptInput.focus();
    }
    
    console.log('AI Content Generator initialized successfully!');
}

// Start the application
document.addEventListener('DOMContentLoaded', initialize);
