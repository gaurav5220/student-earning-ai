/**
 * Simulates an AI API call with realistic delay and response generation
 * @param {string} prompt - The user's input prompt
 * @returns {Promise<string>} - The generated response
 */
async function generateAIResponse(prompt) {
    // Simulate network delay (1.5 to 3 seconds)
    const delay = 1500 + Math.random() * 1500;
    await new Promise(resolve => setTimeout(resolve, delay));
    
    // Simulate occasional errors (5% chance)
    if (Math.random() < 0.05) {
        throw new Error('Network timeout. Please try again.');
    }
    
    // Determine response type based on prompt content
    const promptLower = prompt.toLowerCase();
    let responsePool;
    
    if (promptLower.includes('email') || promptLower.includes('mail')) {
        responsePool = mockResponses.email;
    } else if (promptLower.includes('social') || promptLower.includes('post') || promptLower.includes('tweet')) {
        responsePool = mockResponses.social;
    } else if (promptLower.includes('blog') || promptLower.includes('article') || promptLower.includes('introduction')) {
        responsePool = mockResponses.blog;
    } else {
        responsePool = mockResponses.default;
    }
    
    // Select a random response from the pool
    const randomIndex = Math.floor(Math.random() * responsePool.length);
    return responsePool[randomIndex];
}

// ============================================
// HISTORY MANAGEMENT
// ============================================

/**
 * Loads history from localStorage
 */
function loadHistory() {
    try {
        const stored = localStorage.getItem(STORAGE_KEY);
        if (stored) {
            state.history = JSON.parse(stored);
        }
    } catch (error) {
        console.error('Error loading history:', error);
        state.history = [];
    }
    renderHistory();
    updateHistoryCount();
}

/**
 * Saves history to localStorage
 */
function saveHistory() {
    try {
        localStorage.setItem(STORAGE_KEY, JSON.stringify(state.history));
    } catch (error) {
        console.error('Error saving history:', error);
        showToast('Failed to save history', 'error');
    }
}

/**
 * Adds a new item to history
 * @param {string} prompt - The user's prompt
 * @param {string} response - The AI's response
 */
function addToHistory(prompt, response) {
    const historyItem = {
        id: Date.now(),
        prompt: prompt,
        response: response,
        timestamp: new Date().toISOString()
    };
    
    // Add to beginning of array (newest first)
    state.history.unshift(historyItem);
    
    // Keep only last 50 items
    if (state.history.length > 50) {
        state.history = state.history.slice(0, 50);
    }
    
    saveHistory();
    renderHistory();
    updateHistoryCount();
    
    // Mark as selected
    state.selectedHistoryId = historyItem.id;
}

/**
 * Renders the history list in the sidebar
 */
function renderHistory() {
    if (state.history.length === 0) {
        elements.historyList.innerHTML = `
            <div class="history-empty">
                <i data-lucide="inbox" class="icon-lg"></i>
                <p>No history yet. Start generating content!</p>
            </div>
        `;
        lucide.createIcons();
        return;
    }
    
    elements.historyList.innerHTML = state.history.map(item => `
        <div class="history-item ${item.id === state.selectedHistoryId ? 'active' : ''}" 
             data-id="${item.id}">
            <div class="history-item-prompt">${escapeHtml(item.prompt)}</div>
            <div class="history-item-meta">
                <i data-lucide="clock" class="icon-sm"></i>
                ${formatRelativeTime(item.timestamp)}
            </div>
        </div>
    `).join('');
    
    // Reinitialize icons
    lucide.createIcons();
    
    // Add click handlers
    elements.historyList.querySelectorAll('.history-item').forEach(item => {
        item.addEventListener('click', () => {
            const id = parseInt(item.dataset.id);
            loadHistoryItem(id);
        });
    });
}

/**
 * Loads a specific history item
 * @param {number} id - The history item ID
 */
function loadHistoryItem(id) {
    const item = state.history.find(h => h.id === id);
    if (!item) return;
    
    state.selectedHistoryId = id;
    state.currentPrompt = item.prompt;
    state.currentResponse = item.response;
    
    // Update input
    elements.promptInput.value = item.prompt;
    updateCharCount();
    
    // Show output
    showOutput(item.response, item.timestamp);
    
    // Update history UI
    renderHistory();
    
    // Close sidebar on mobile
    closeSidebar();
}

/**
 * Clears all history
 */
function clearHistory() {
    if (state.history.length === 0) {
        showToast('History is already empty', 'info');
        return;
    }
    
    if (confirm('Are you sure you want to clear all history? This cannot be undone.')) {
        state.history = [];
        state.selectedHistoryId = null;
        saveHistory();
        renderHistory();
        updateHistoryCount();
        showToast('History cleared successfully', 'success');
    }
}

/**
 * Updates the history count display
 */
function updateHistoryCount() {
    const count = state.history.length;
    elements.historyCount.textContent = `${count} item${count !== 1 ? 's' : ''}`;
}

// ============================================
// UI STATE MANAGEMENT
// ============================================

/**
 * Shows the loading state
 */
function showLoading() {
    elements.emptyState.classList.add('hidden');
    elements.outputContent.classList.add('hidden');
    elements.errorState.classList.add('hidden');
    elements.loadingState.classList.remove('hidden');
    elements.outputActions.classList.remove('visible');
    elements.generateBtn.disabled = true;
    state.isGenerating = true;
}

/**
 * Shows the output with typing effect
 * @param {string} text - The response text
 * @param {string} timestamp - Optional timestamp for history items
 */
function showOutput(text, timestamp = null) {
    elements.emptyState.classList.add('hidden');
    elements.loadingState.classList.add('hidden');
    elements.errorState.classList.add('hidden');
    elements.outputContent.classList.remove('hidden');
    elements.outputActions.classList.add('visible');
    elements.generateBtn.disabled = false;
    state.isGenerating = false;
    
    // Update meta information
    elements.generatedTime.textContent = timestamp 
        ? formatRelativeTime(timestamp) 
        : 'Just now';
    elements.wordCount.textContent = `${countWords(text)} words`;
    
    // Typing effect
    typeText(text);
}

/**
 * Shows the error state
 * @param {string} message - The error message
 */
function showError(message) {
    elements.emptyState.classList.add('hidden');
    elements.loadingState.classList.add('hidden');
    elements.outputContent.classList.add('hidden');
    elements.errorState.classList.remove('hidden');
    elements.outputActions.classList.remove('visible');
    elements.errorMessage.textContent = message;
    elements.generateBtn.disabled = false;
    state.isGenerating = false;
}

/**
 * Creates a typing effect for the output text
 * @param {string} text - The text to type
 */
function typeText(text) {
    elements.outputText.innerHTML = '';
    let index = 0;
    const speed = 10; // milliseconds per character
    
    // Create cursor element
    const cursor = document.createElement('span');
    cursor.className = 'cursor';
    
    function type() {
        if (index < text.length) {
            // Get next chunk (type 2-5 characters at a time for speed)
            const chunkSize = Math.floor(Math.random() * 4) + 2;
            const chunk = text.slice(index, index + chunkSize);
            
            // Remove cursor, add text, add cursor back
            cursor.remove();
            elements.outputText.innerHTML += escapeHtml(chunk).replace(/\n/g, '<br>');
            elements.outputText.appendChild(cursor);
            
            index += chunkSize;
            setTimeout(type, speed);
        } else {
            // Remove cursor when done
            setTimeout(() => cursor.remove(), 1000);
        }
    }
    
    elements.outputText.appendChild(cursor);
    type();
}

