// ============================================
// GENERATION HANDLERS
// ============================================

/**
 * Handles the generate button click
 */
async function handleGenerate() {
    const prompt = elements.promptInput.value.trim();
    
    if (!prompt) {
        showToast('Please enter a prompt', 'error');
        elements.promptInput.focus();
        return;
    }
    
    if (state.isGenerating) {
        showToast('Generation in progress...', 'info');
        return;
    }
    
    state.currentPrompt = prompt;
    showLoading();
    
    try {
        const response = await generateAIResponse(prompt);
        state.currentResponse = response;
        showOutput(response);
        addToHistory(prompt, response);
        showToast('Content generated successfully!', 'success');
    } catch (error) {
        showError(error.message || 'An unexpected error occurred');
        showToast(error.message || 'Generation failed', 'error');
    }
}

/**
 * Handles regeneration with the same prompt
 */
async function handleRegenerate() {
    if (!state.currentPrompt) {
        showToast('No prompt to regenerate', 'error');
        return;
    }
    
    showLoading();
    
    try {
        const response = await generateAIResponse(state.currentPrompt);
        state.currentResponse = response;
        showOutput(response);
        addToHistory(state.currentPrompt, response);
        showToast('Content regenerated!', 'success');
    } catch (error) {
        showError(error.message || 'An unexpected error occurred');
        showToast(error.message || 'Regeneration failed', 'error');
    }
}

// ============================================
// ACTION HANDLERS
// ============================================

/**
 * Copies the current response to clipboard
 */
async function copyToClipboard() {
    if (!state.currentResponse) {
        showToast('Nothing to copy', 'error');
        return;
    }
    
    try {
        await navigator.clipboard.writeText(state.currentResponse);
        showToast('Copied to clipboard!', 'success');
    } catch (error) {
        // Fallback for older browsers
        const textArea = document.createElement('textarea');
        textArea.value = state.currentResponse;
        document.body.appendChild(textArea);
        textArea.select();
        document.execCommand('copy');
        document.body.removeChild(textArea);
        showToast('Copied to clipboard!', 'success');
    }
}

/**
 * Downloads the current response as a .txt file
 */
function downloadResult() {
    if (!state.currentResponse) {
        showToast('Nothing to download', 'error');
        return;
    }
    
    const content = `Prompt:\n${state.currentPrompt}\n\n---\n\nResponse:\n${state.currentResponse}`;
    const blob = new Blob([content], { type: 'text/plain' });
    const url = URL.createObjectURL(blob);
    
    const a = document.createElement('a');
    a.href = url;
    a.download = `ai-generated-${Date.now()}.txt`;
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
    URL.revokeObjectURL(url);
    
    showToast('File downloaded!', 'success');
}

